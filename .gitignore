# ── Go ────────────────────────────────────────────────────────────────────────
# Compiled binaries (root-level only — anchored so cmd/meru* dirs are not ignored)
/meru
/meru-node
*.exe
*.exe~

# Test artifacts
*.test
coverage.out
coverage.html

# GoReleaser output
dist/

# ── Web UI ────────────────────────────────────────────────────────────────────
# Compiled React app (generated by `npm run build`, copied to internal/ui/dist)
internal/ui/dist/

# npm / Node (root-level guard; web/.gitignore covers the web/ subtree)
node_modules/

# ── Runtime data ──────────────────────────────────────────────────────────────
# Default meru data directory created by `meru serve`
.meru/

# SQLite databases
*.db
*.db-shm
*.db-wal

# ── Docs (Jekyll) ─────────────────────────────────────────────────────────────
docs/_site/
docs/.bundle/
docs/.sass-cache/
docs/.jekyll-cache/
docs/.jekyll-metadata

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
